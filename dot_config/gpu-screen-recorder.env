WINDOW=DP-1
CONTAINER=mkv
BITRATE_MODE=cbr
QUALITY=30000
CODEC=av1
AUDIO_CODEC=opus
AUDIO_DEVICE=default_output
SECONDARY_AUDIO_DEVICE=default_input
